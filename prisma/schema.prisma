generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id String @id @default(cuid())

  email              String? @unique
  customerName       String
  phoneNumber        String
  assignedEmployeeId String?

  assignedEmployeeName String?

  startedAt DateTime?

  completedAt DateTime?

  paymentMode String?

  discount Int @default(0)

  finalAmount Int?

  notes String?

  referralCode     String?
  referralRewarded Boolean @default(false)

  pickupDrop  Boolean
  lastLogin   DateTime?
  bookingDate String
  bookingTime String

  totalCost Int

  status String @default("Pending")

  assignedTo String?
  details    Json? // [{ vehicleType, serviceId, addons: [id] }]

  customerRating Int?

  createdAt  DateTime  @default(now())
  customerId String? // Link to Customer model
  customer   Customer? @relation(fields: [customerId], references: [id])
  serviceId  String? // Link to Service model
  service    Service?  @relation(fields: [serviceId], references: [id])
}

model Customer {
  id                String    @id @default(cuid())
  customerName      String?
  phoneNumber       String?   @unique
  whatsAppNumber    String?
  vehicleNumber     String? // This old field will be managed by new Vehicle model
  vehicleType       String? // This old field will be managed by new Vehicle model
  totalVisits       Int       @default(0)
  totalSpent        Int       @default(0)
  lastVisit         DateTime?
  isBlacklisted     Boolean   @default(false)
  tag               String? // This old field will be replaced by categories
  email             String?   @unique
  password          String?
  resetToken        String?
  resetTokenExpires DateTime?
  otpHash           String?
  otpExpires        DateTime?
  referralCode      String?   @unique
  referralPoints    Int       @default(0)
  referredBy        String?
  notes             String?
  primaryCategory   String    @default("NEW")
  secondaryCategory String? // For INACTIVE
  isCategoryLocked  Boolean   @default(false)
  categoryHistory   Json? // Store an array of objects { date, category, changedBy }
  visitHistory      Json? // Store an array of visit dates
  spendingHistory   Json? // Store an array of { date, amount }
  createdAt         DateTime  @default(now())

  refreshTokens RefreshToken[]
  vehicles      Vehicle[]
  memberships   Membership[]
  rewardPoints  RewardPoint[]
  Booking       Booking[]
  chatSessions  ChatSession[]
}

model Employee {
  id String @id @default(cuid())

  employeeCode String @unique

  name String

  phoneNumber String @unique

  email      String?   @unique
  otpHash    String?
  otpExpires DateTime?

  password String

  role String

  status String @default("active")

  salaryPerDay Int

  joiningDate DateTime @default(now())

  aadhaarNumber String?

  address String?

  emergencyContact String?

  branch String?

  shiftType String?

  notes String?

  jobsCompleted Int @default(0)

  revenueGenerated Int @default(0)

  totalUpsells Int @default(0)

  attendancePercent Float @default(100)

  customerRating Float @default(5)

  penalties Int @default(0)

  incentives Int @default(0)

  lastLogin DateTime?

  isActive Boolean @default(true)

  expenses Expense[]
  createdAt DateTime @default(now())
}

model Attendance {
  id String @id @default(cuid())

  employeeId String

  employeeCode String

  employeeName String

  checkIn DateTime @default(now())

  checkOut DateTime?

  attendanceStatus String

  notes String?
}

model Expense {
  id String @id @default(cuid())

  // Required fields
  date DateTime
  amount Int

  // Optional fields
  time String?
  category String?
  description String?
  paidTo String?
  paymentMode String?
  invoiceNumber String?
  vendorGSTNumber String?
  receiptUrl String?
  notes String?
  employeeId String?
  employee Employee? @relation(fields: [employeeId], references: [id])
  branch String?
  project String?
  costCenter String?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
   updatedBy String?
   @@index([date])
   @@index([category])
   @@index([paymentMode])
  attachments Attachment[]
}
model ExpenseCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  disabled  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PaymentMode {
  id        String   @id @default(cuid())
  name      String   @unique
  disabled  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attachment {
  id        String   @id @default(cuid())
  expenseId String
  url       String
  mimeType  String
  createdAt DateTime @default(now())
  expense   Expense @relation(fields: [expenseId], references: [id])
}

model DailyClosing {
  id String @id @default(cuid())

  date String @unique

  totalRevenue Int

  totalExpenses Int

  netProfit Int

  totalBookings Int

  cashRevenue Int

  upiRevenue Int

  cashClosingAfterExpenses Int? @default(0)
  dailyWageDeductions      Int? @default(0)
  onlinePaymentCollected   Int? @default(0)

  createdAt DateTime @default(now())
}

model ReferralRedemption {
  id         String   @id @default(cuid())
  customerId String
  points     Int
  createdAt  DateTime @default(now())
}

model RefreshToken {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  customerId String
  expiresAt  DateTime
  revoked    Boolean  @default(false)
  replacedBy String?
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Service {
  id          String    @id @default(cuid())
  name        String
  description String?
  price       Int
  category    String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  Booking     Booking[]
}

model Offer {
  id                          String    @id @default(cuid())
  title                       String
  description                 String?
  discountPercent             Int       @default(0)
  discountAmount              Int       @default(0)
  validDays                   String[]
  startTime                   String?
  endTime                     String?
  applicableServiceIds        String[]
  minVehicles                 Int       @default(1)
  discountSecondVehicleAmount Int       @default(0)
  code                        String?   @unique
  isActive                    Boolean   @default(true)
  validUntil                  DateTime?
  imageUrl                    String?
  createdAt                   DateTime  @default(now())
}

model ApprovalRequest {
  id           String   @id @default(cuid())
  entityType   String
  entityId     String?
  action       String
  managerId    String
  managerName  String?
  previousData String? // JSON snapshot
  newData      String? // JSON snapshot
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  expiresAt    DateTime
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @default(now()) @updatedAt
}

model Vehicle {
  id          String    @id @default(cuid())
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  plateNumber String?   @unique
  type        String?
  brand       String?
  model       String?
  color       String?
  value       Int? // in Lakhs, e.g., 15 for 15 Lakhs
  createdAt   DateTime  @default(now())
}

model LoyaltyTier {
  id        String   @id @default(cuid())
  name      String   @unique
  minVisits Int?
  minSpend  Int?
  benefits  String?  @db.Text // JSON description of benefits
  rank      Int      @unique // Priority for auto-assignment
  createdAt DateTime @default(now())
}

model MembershipPlan {
  id           String       @id @default(cuid())
  name         String       @unique
  price        Int
  durationDays Int
  benefits     String?      @db.Text // JSON description of benefits
  createdAt    DateTime     @default(now())
  memberships  Membership[]
}

model RewardPoint {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  points      Int
  type        String // EARNED, REDEEMED
  bookingId   String?
  description String?
  createdAt   DateTime @default(now())
}

model Membership {
  id               String         @id @default(cuid())
  customerId       String
  customer         Customer       @relation(fields: [customerId], references: [id])
  membershipPlanId String
  membershipPlan   MembershipPlan @relation(fields: [membershipPlanId], references: [id])
  startDate        DateTime
  endDate          DateTime?
  status           String         @default("ACTIVE")
  createdAt        DateTime       @default(now())
}
model Event {
  id          Int      @id @default(autoincrement())
  date        DateTime @unique
  type        String   // e.g., "holiday", "promo", "local_festival"
  description String?
}

model WeatherLog {
  id          Int      @id @default(autoincrement())
  date        DateTime @unique // UTC date
  temperature Float    // average temperature (°C)
  condition   String   // e.g., "Clear", "Rain", "Snow"
} 

// Blog platform models
model Author {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  bio       String?
  avatarUrl String?
  posts     BlogPost[]
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  slug        String    @unique
  description String?
  seoTitle    String?
  seoDesc     String?
  posts       BlogPost[] @relation("PostCategories")
}

model Tag {
  id   Int    @id @default(autoincrement())
  name String @unique
  slug String @unique
  posts BlogPost[] @relation("PostTags")
}

model Media {
  id         Int      @id @default(autoincrement())
  url        String
  altText    String?
  width      Int?
  height     Int?
  uploadedAt DateTime @default(now())
  post       BlogPost?
}

model BlogPost {
  id                Int        @id @default(autoincrement())
  title             String
  slug              String     @unique
  excerpt           String?
  content           String
  publishedAt       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  status            String     @default("draft")
  viewCount         Int        @default(0)
  likeCount         Int        @default(0)
  authorId          Int
  author            Author     @relation(fields: [authorId], references: [id])
  categories        Category[] @relation("PostCategories")
  tags              Tag[]      @relation("PostTags")
  featuredImageId   Int? @unique
  featuredImage     Media?     @relation(fields: [featuredImageId], references: [id])
  seoTitle          String?
  seoDescription    String?
  focusKeyword      String?
  canonicalUrl      String?
  openGraphImageUrl String?
  views            BlogView[]
  likes            BlogLike[]
  scheduledPosts   ScheduledPost[]
}

model BlogView {
  id        Int      @id @default(autoincrement())
  postId    Int
  post      BlogPost @relation(fields: [postId], references: [id])
  ip        String
  userAgent String?
  viewedAt  DateTime @default(now())
}

model BlogLike {
  id     Int      @id @default(autoincrement())
  postId Int
  post   BlogPost @relation(fields: [postId], references: [id])
  ip     String
  likedAt DateTime @default(now())
}

model ScheduledPost {
  id          Int      @id @default(autoincrement())
  postId      Int
  post        BlogPost @relation(fields: [postId], references: [id])
  scheduledFor DateTime
  timezone    String
  status      String   @default("queued")
}

model ChatBotKnowledge {
  id        Int      @id @default(autoincrement())
  question  String   @db.Text
  answer    String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatSession {
  id           String        @id @default(cuid())
  customerName String
  customerId   String?
  customer     Customer?     @relation(fields: [customerId], references: [id])
  isPermanent  Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  messages     ChatMessage[]
}

model ChatMessage {
  id        Int         @id @default(autoincrement())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender    String      // "user" | "bot"
  text      String      @db.Text
  createdAt DateTime    @default(now())
}

model InventoryItem {
  id          String   @id @default(cuid())
  name        String   @unique
  quantity    Int
  unit        String   // e.g., "Liters", "Pieces", "Boxes"
  minStock    Int      @default(5)
  costPerUnit Int
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model Payroll {
  id           String    @id @default(cuid())
  employeeId   String
  employeeName String
  employeeCode String
  month        String    // e.g., "2026-06"
  workingDays  Int
  dailyWage    Int
  advances     Int       @default(0)
  deductions   Int       @default(0)
  netPayable   Int
  status       String    @default("Unpaid") // "Paid" | "Unpaid"
  paidAt       DateTime?
  createdAt    DateTime  @default(now())
}

model Refund {
  id           String   @id @default(cuid())
  bookingId    String   @unique
  bookingRef   String
  customerName String
  amount       Int
  reason       String
  paymentMode  String   @default("UPI")
  status       String   @default("Processed") // "Processed" | "Pending"
  createdAt    DateTime @default(now())
}

model Transaction {
  id               String   @id @default(cuid())
  date             String // Date string format, e.g. YYYY-MM-DD
  amount           Int
  paymentMode      String // Cash, UPI, Card, etc.
  time             String?
  customerName     String?
  customerMobile   String?
  customerId       String? // Optional relation back-reference/info
  vehicleNumber    String?
  vehicleType      String?
  serviceOpted     String?
  addonServices    String?
  assignedEmployee String?
  discountAmount   Int?     @default(0)
  finalAmount      Int?
  notes            String?
  invoiceId        String   @unique @default(cuid()) // Auto Generated
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  createdBy        String?  // Username or email of creator
}

